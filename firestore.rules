rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Lookup table: inviteCodes/{code} -> { familyId }
    // Required because Firestore rules cannot safely allow querying
    // families by inviteCode without exposing all family documents.
    match /inviteCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['familyId', 'createdAt'])
        && request.resource.data.familyId is string;
      allow update, delete: if false;
    }

    match /families/{familyId} {
      // Members can read their family
      allow read: if request.auth != null
        && request.auth.uid in resource.data.members;

      // Creator becomes first member on create
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() == 1
        && request.resource.data.inviteCode is string
        && request.resource.data.name is string;

      // Members can update, OR a user can add themselves (join flow)
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members
        || (
          request.auth.uid in request.resource.data.members
          && !(request.auth.uid in resource.data.members)
        )
      );

      allow delete: if false;

      match /kids/{kidId} {
        allow read, create, update, delete: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members;
      }

      match /transactions/{txnId} {
        allow read, create, update, delete: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members;
      }
    }
  }
}
